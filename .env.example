TELEGRAM_BOT_TOKEN=put_telegram_token_here

# Groq
GROQ_API_KEY=put_groq_key_here
GROQ_MODEL=openai/gpt-oss-120b

# Services/prices file (CSV opened by Excel)
SERVICES_CSV=services_pricelist.csv

# Google Calendar (Service Account)
GOOGLE_CALENDAR_ID=your_calendar_id_here
# Option A (file path)
GOOGLE_SERVICE_ACCOUNT_JSON=path\to\service-account.json
# Option B (raw JSON in env var) — convenient for Render secrets
GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT=

# Optional: restrict bookings window (local time)
SALON_TIMEZONE=Asia/Jerusalem
SALON_NAME=Aaron
ADDRESS=Jerusalem, Israel
WORK_START_HOUR=10
WORK_END_HOUR=20

# Render/Webhook (optional)
# If set, bot will run in webhook mode (good for Render)
WEBHOOK_URL=
